{
  "name": "@cparra/apexdocs",
  "version": "2.25.0-alpha.0",
  "description": "Library with CLI capabilities to generate documentation for Salesforce Apex classes.",
  "keywords": [
    "apex",
    "salesforce",
    "documentation",
    "cli",
    "apex-docs",
    "docs"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "require": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "apexdocs-generate": "dist/cli/generate.js"
  },
  "scripts": {
    "test": "jest --coverage",
    "pkgroll:watch": "pkgroll --watch",
    "pkgroll:help": "pkgroll --help",
    "build": "rimraf ./lib && npm run lint && pkgroll",
    "lint": "eslint \"./src/**/*.{js,ts}\" --quiet --fix",
    "prepare": "npm run build",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags",
    "docs:init": "docsify init docs",
    "docs:serve": "docsify serve docs",
    "execute:example": "rimraf ./docs/types && node dist/cli/generate.js -s examples/force-app -t docs/types --scope global public private protected -g docsify --defaultGroupName \"Misc Group\" --namespace nspc --title \"Sample Documentation\" --documentationRootDir types",
    "execute:example:index:only": "node dist/cli/generate.js -s examples/force-app -t docs --scope global public private -g docsify --indexOnly",
    "execute:example:openapi": "node dist/cli/generate.js -s examples/force-app -t docs -g openapi --openApiTitle \"Sample REST Api\" --namespace nspc --openApiFileName restapi"
  },
  "author": "Cesar Parra",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cesarParra/apexdocs"
  },
  "devDependencies": {
    "@jackfranklin/rollup-plugin-markdown": "^0.4.0",
    "@types/html-entities": "^1.3.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/shelljs": "^0.8.15",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "docsify": "^4.13.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^13.2.1",
    "pkgroll": "^2.1.1",
    "prettier": "^2.8.8",
    "rimraf": "^3.0.2",
    "rollup": "^4.18.0",
    "ts-jest": "^29.1.4",
    "typescript": "^4.8.4"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@cparra/apex-reflection": "2.9.2",
    "@types/js-yaml": "^4.0.9",
    "@types/yargs": "^15.0.3",
    "chalk": "^4.1.2",
    "cosmiconfig": "^9.0.0",
    "fast-xml-parser": "^4.4.0",
    "fp-ts": "^2.16.7",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "log-update": "4.0.0",
    "yargs": "^16.0.3"
  }
}
